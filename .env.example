# Copy to .env.local for local dev, or set these in your host (e.g. Vercel
# Project Settings -> Environment Variables) for production.

# Tenant + login credentials
FARMOVA_TENANT=farmova
FARMOVA_USERNAME=admin@farmova.app
FARMOVA_PASSWORD=change-me

# Secret used to sign the session cookie. Use a long random string in prod.
FARMOVA_AUTH_SECRET=replace-with-a-long-random-secret
